@app.get("/v1/health/detailed")
async def health_detailed():
    import psutil
    health = {
        "status": "healthy",
        "timestamp": time.time(),
        "node": NODE_ID,
        "components": {
            "core": core is not None,
            "redis": check_redis(),
            "vector_memory": core.vector_memory is not None,
            "model_router": core.model_router is not None
        },
        "system": {
            "cpu_percent": psutil.cpu_percent(),
            "memory_percent": psutil.virtual_memory().percent,
            "disk_usage": psutil.disk_usage("/").percent
        },
        "metrics": {
            "active_modules": len(core.modules.get_active()),
            "memory_vectors": core.vector_memory.index.ntotal,
            "total_conversations": get_conversation_count()
        }
    }
    return health

def check_redis():
    try:
        import redis
        r = redis.from_url(REDIS_URL)
        return r.ping()
    except:
        return False

def get_conversation_count():
    # Query SQLite for count
    return core.memory.conn.execute("SELECT COUNT(*) FROM conversations").fetchone()[0]

