# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-...

# Environment
ENVIRONMENT=development

# Database – SQLite for quick demos (production uses PostgreSQL via Docker)
DATABASE_URL=sqlite+aiosqlite:///./crownstar.db

# Redis (optional – if not running, disable rate limiting)
REDIS_URL=redis://localhost:6379/0

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production

# Moark Serverless API (Alternative to DeepSeek)
# DEEPSEEK_BASE_URL=https://api.moark.ai/v1/
# DEEPSEEK_API_KEY=your_moark_token_here

# License (optional – leave empty for free version)
CROWNSTAR_LICENSE_KEY=
LICENSE_SECRET=your-secret-key-for-licenses

# CrownStar control shell
DEFAULT_TEMPERATURE=0.7
DEFAULT_MIN_LENGTH=10
DEFAULT_MAX_LENGTH=2048
MEMORY_WINDOW=5
