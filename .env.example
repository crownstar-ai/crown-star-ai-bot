# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-...

# Environment
ENVIRONMENT=development

# Database – SQLite for quick demos (production uses PostgreSQL via Docker)
DATABASE_URL=sqlite+aiosqlite:///./crownstar.db

# Redis (optional – if not running, disable rate limiting)
REDIS_URL=redis://localhost:6379/0

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production
