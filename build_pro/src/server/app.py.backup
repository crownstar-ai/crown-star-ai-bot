logger = logging.getLogger(__name__)

# --------------------------------------------------------------------
# Pydantic models for request/response
# --------------------------------------------------------------------
class ChatRequest(BaseModel):
    query: str
    tier: str = "enterprise"
    temperature: Optional[float] = None
    min_length: Optional[int] = None
    max_length: Optional[int] = None
    mode: str = "regal_futurism"
    stream: bool = False
    conversation_id: Optional[str] = None

class ChatResponse(BaseModel):
    response: str
    conversation_id: str
    tokens_used: int
    tier: str
    latency_ms: float

class ConversationMetadata(BaseModel):
    id: str
    title: str
    created: float
    updated: float
    message_count: int

class ErrorResponse(BaseModel):
    error: str
    code: str
    details: Optional[str] = None

# --------------------------------------------------------------------
# Lifespan manager (startup / shutdown)
# --------------------------------------------------------------------
@asynccontextmanager
async def lifespan(app: FastAPI):
    # Startup: initialise CrownStar core
    logger.info("Starting CrownStar‑Absolute Enterprise Web Server")
    config = UnifiedModelConfig()
    config.device = "cuda" if torch.cuda.is_available() else "cpu"
    app.state.core = CrownStarCore(config=config, lazy_load=False)
    app.state.core.ensure_cortex()
    app.state.core.ensure_index()
    app.state.core.ensure_memory()
    app.state.core.ensure_shell()
    logger.info("CrownStarCore initialised")
    
    # Authentication
    auth_config = AuthConfig()
    auth_config.jwt_secret = os.environ.get("CROWNSTAR_JWT_SECRET", "change-me-in-production")
    app.state.auth = AuthMiddleware(auth_config)
    app.state.key_manager = APIKeyManager()
    
    yield
    # Shutdown
    await app.state.core.shutdown()
    logger.info("Server shutdown complete")

# --------------------------------------------------------------------
# Create FastAPI app
# --------------------------------------------------------------------
app = FastAPI(
    title="CrownStar‑Absolute API",
    description="Enterprise REST API for the world's most powerful AI",
    version="1.0.0",
    lifespan=lifespan,
    docs_url="/docs",
    redoc_url="/redoc"
)

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],  # Configure appropriately in production
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

security = HTTPBearer(auto_error=False)

# --------------------------------------------------------------------
# Authentication dependency
# --------------------------------------------------------------------
async def get_current_user(credentials: Optional[HTTPAuthorizationCredentials] = Depends(security),
                           x_api_key: Optional[str] = None):
    """Authenticate via Bearer token (JWT) or X-API-Key header."""
    auth_info = None
    token = credentials.credentials if credentials else None
    if token:
        auth_info, err = app.state.auth.authenticate(bearer_token=token)
    elif x_api_key:
        auth_info, err = app.state.auth.authenticate(api_key=x_api_key)
    else:
        # Try to get API key from headers
        # (FastAPI doesn't automatically inject header; we'll read from request in endpoint)
        pass
    if not auth_info:
        raise HTTPException(status_code=401, detail="Authentication required")
    return auth_info

# Optional auth (for endpoints that can be public but still want to know user)
async def get_optional_user(credentials: Optional[HTTPAuthorizationCredentials] = Depends(security)):
    if credentials:
        auth_info, _ = app.state.auth.authenticate(bearer_token=credentials.credentials)
        return auth_info
    return None

# --------------------------------------------------------------------
# Health check
# --------------------------------------------------------------------
@app.get("/health", response_model=Dict)
async def health_check():
    return {
        "status": "ok",
        "version": "1.0.0",
        "tier": "enterprise",
        "uptime_seconds": time.time() - getattr(app.state, 'start_time', time.time())
    }

@app.get("/metrics")
async def metrics():
    """Prometheus‑style metrics (simplified)"""
    core = app.state.core
    stats = core.get_stats() if hasattr(core, 'get_stats') else {}
    return {
        "model_parameters": stats.get("config", {}).get("model_params", 0),
        "index_size": stats.get("index_size", 0),
        "memory_entries": stats.get("memory_size", 0),
        "device": stats.get("config", {}).get("device", "cpu")
    }

# --------------------------------------------------------------------
# Chat endpoints
# --------------------------------------------------------------------
@app.post("/v1/chat/completions", response_model=ChatResponse)
async def chat_completions(request: ChatRequest, background_tasks: BackgroundTasks,
                           auth: Dict = Depends(get_current_user)):
    """
    Non‑streaming chat completion.
    """
    start_time = time.perf_counter()
    core = app.state.core
    
    # Apply overrides from request
    original_tier = core.shell.state.tier
    if request.tier:
        core.shell.state.tier = request.tier
    if request.temperature:
        core.shell.state.temperature = request.temperature
    if request.min_length:
        core.shell.state.min_length = request.min_length
    if request.max_length:
        core.shell.state.max_length = request.max_length
    if request.mode:
        core.shell.set_mode(request.mode)
    
    # Use conversation ID if provided
    conv_id = request.conversation_id
    if conv_id and hasattr(core, 'shell') and hasattr(core.shell, 'load_conversation'):
        # Implement loading if needed
        pass
    
    response = await core.answer(request.query, tier=request.tier)
    
    # Restore original settings
    core.shell.state.tier = original_tier
    
    latency_ms = (time.perf_counter() - start_time) * 1000
    tokens_used = len(response) // 4  # Approximate
    
    # Record telemetry
    background_tasks.add_task(record_telemetry, request.query, response, request.tier, latency_ms)
    
    return ChatResponse(
        response=response,
        conversation_id=conv_id or str(uuid.uuid4()),
        tokens_used=tokens_used,
        tier=request.tier,
        latency_ms=latency_ms
    )

@app.post("/v1/chat/stream")
async def chat_stream(request: ChatRequest, auth: Dict = Depends(get_current_user)):
    """
    Streaming chat completion (Server‑Sent Events).
    """
    core = app.state.core
    
    async def event_generator():
        start_time = time.perf_counter()
        # For streaming, we need to simulate token‑by‑token generation
        # Simplified: generate full response then stream as tokens
        response = await core.answer(request.query, tier=request.tier)
        # Simulate token streaming (split into words)
        words = response.split()
        for i, word in enumerate(words):
            yield f"data: {json.dumps({'token': word + (' ' if i < len(words)-1 else ''), 'done': False})}\n\n"
            await asyncio.sleep(0.05)
        yield f"data: {json.dumps({'done': True, 'full_response': response})}\n\n"
    
    return StreamingResponse(event_generator(), media_type="text/event-stream")

# --------------------------------------------------------------------
# Conversation management
# --------------------------------------------------------------------
@app.get("/v1/conversations", response_model=List[ConversationMetadata])
async def list_conversations(auth: Dict = Depends(get_current_user)):
    """List all conversations for the authenticated user."""
    core = app.state.core
    if hasattr(core, 'shell') and hasattr(core.shell, 'list_conversations'):
        convs = core.shell.list_conversations()
        return [ConversationMetadata(**c) for c in convs]
    return []

@app.get("/v1/conversations/{conv_id}")
async def get_conversation(conv_id: str, auth: Dict = Depends(get_current_user)):
    """Get full conversation history."""
    core = app.state.core
    if hasattr(core, 'shell') and hasattr(core.shell, 'get_conversation'):
        messages = core.shell.get_conversation(conv_id)
        return {"conversation_id": conv_id, "messages": messages}
    raise HTTPException(status_code=404, detail="Conversation not found")

@app.delete("/v1/conversations/{conv_id}")
async def delete_conversation(conv_id: str, auth: Dict = Depends(get_current_user)):
    core = app.state.core
    if hasattr(core, 'shell') and hasattr(core.shell, 'delete_conversation'):
        core.shell.delete_conversation(conv_id)
        return {"success": True}
    raise HTTPException(status_code=404)

@app.post("/v1/conversations/{conv_id}/rename")
async def rename_conversation(conv_id: str, title: str, auth: Dict = Depends(get_current_user)):
    core = app.state.core
    if hasattr(core, 'shell') and hasattr(core.shell, 'rename_conversation'):
        core.shell.rename_conversation(conv_id, title)
        return {"success": True}
    raise HTTPException(status_code=404)

@app.post("/v1/conversations/{conv_id}/export")
async def export_conversation(conv_id: str, format: str = "json", auth: Dict = Depends(get_current_user)):
    core = app.state.core
    if hasattr(core, 'shell') and hasattr(core.shell, 'export_conversation'):
        exported = core.shell.export_conversation(conv_id, format)
        media_type = "application/json" if format == "json" else "text/plain"
        filename = f"conversation_{conv_id}.{ 'json' if format=='json' else 'md' if format=='markdown' else 'txt'}"
        return Response(content=exported, media_type=media_type, headers={"Content-Disposition": f"attachment; filename={filename}"})
    raise HTTPException(status_code=404)

# --------------------------------------------------------------------
# Admin endpoints (enterprise only)
# --------------------------------------------------------------------
@app.get("/v1/admin/stats")
async def admin_stats(auth: Dict = Depends(get_current_user)):
    """Get detailed system statistics (requires admin scope)."""
    if "admin" not in auth.get("scopes", []):
        raise HTTPException(status_code=403, detail="Admin scope required")
    core = app.state.core
    stats = core.get_stats() if hasattr(core, 'get_stats') else {}
    # Add extra metrics
    stats["memory"] = core.memory.get_statistics() if core.memory else {}
    stats["cortex"] = {"enabled": core.cortex is not None}
    return stats

@app.post("/v1/admin/clear_cache")
async def clear_cache(auth: Dict = Depends(get_current_user)):
    if "admin" not in auth.get("scopes", []):
        raise HTTPException(status_code=403)
    core = app.state.core
    if core.cortex:
        core.cortex._harvest_cache.clear() if hasattr(core.cortex, '_harvest_cache') else None
    if core.index:
        core.index.clear() if hasattr(core.index, 'clear') else None
    return {"success": True}

@app.post("/v1/admin/rebuild_index")
async def rebuild_index(auth: Dict = Depends(get_current_user)):
    if "admin" not in auth.get("scopes", []):
        raise HTTPException(status_code=403)
    core = app.state.core
    if core.index and hasattr(core.index, 'rebuild_from_metadata'):
        core.index.rebuild_from_metadata()
        return {"success": True}
    raise HTTPException(status_code=501, detail="Index rebuild not implemented")

# --------------------------------------------------------------------
# Telemetry helper
# --------------------------------------------------------------------
async def record_telemetry(query: str, response: str, tier: str, latency_ms: float):
    """Background task to record usage (if telemetry enabled)."""
    try:
        from src.licensing.telemetry import TelemetryCollector
        telemetry = TelemetryCollector()
        telemetry.record_request(tier, endpoint="chat", latency_ms=latency_ms, tokens_generated=len(response)//4)
    except Exception as e:
        logger.debug(f"Telemetry failed: {e}")

# --------------------------------------------------------------------
# Main entry point (if run directly)
# --------------------------------------------------------------------
if __name__ == "__main__":
    import uvicorn
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default="0.0.0.0")
    parser.add_argument("--port", type=int, default=8080)
    parser.add_argument("--reload", action="store_true")
    args = parser.parse_args()
    
    uvicorn.run(
        "app:app",
        host=args.host,
        port=args.port,
        reload=args.reload,
        log_level="info"
    )
