[翻译占位] <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>CrownStar‑Absolute – Diagnostics Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #0a0a14;
            --bg-glass: rgba(20, 20, 35, 0.65);
            --bg-glass-solid: rgba(20, 20, 35, 0.95);
            --primary: #b8860b;
            --primary-light: #d4af37;
            --primary-dark: #8b6508;
            --accent: #6a0dad;
            --text-light: #f0f0f5;
            --text-muted: #a0a0b5;
            --border-light: rgba(180, 130, 50, 0.3);
            --success: #2ecc71;
            --warning: #f39c12;
            --error: #e74c3c;
            --info: #3498db;
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            --blur: blur(12px);
        }

        body {
            font-family: 'Segoe UI', 'Inter', system-ui, sans-serif;
            background: radial-gradient(circle at 10% 20%, #1a1a2e, #0a0a14);
            color: var(--text-light);
            min-height: 100vh;
            padding: 2rem;
        }

        .dashboard {
            max-width: 1400px;
            margin: 0 auto;
        }

        h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--primary-light), var(--primary));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .subtitle {
            color: var(--text-muted);
            margin-bottom: 2rem;
            border-left: 3px solid var(--primary);
            padding-left: 1rem;
        }

        /* Grid layout */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .card {
            background: var(--bg-glass);
            backdrop-filter: var(--blur);
            border: 1px solid var(--border-light);
            border-radius: 24px;
            padding: 1.25rem;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: var(--shadow);
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--border-light);
        }

        .card-header h3 {
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .card-header .icon {
            font-size: 1.4rem;
        }

        .metric {
            font-size: 2rem;
            font-weight: bold;
            color: var(--primary-light);
            margin-bottom: 0.25rem;
        }

        .metric-unit {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        .metric-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-top: 0.5rem;
        }

        .status-badge {
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: bold;
        }
        .status-ok { background: var(--success); color: #000; }
        .status-warning { background: var(--warning); color: #000; }
        .status-error { background: var(--error); color: #fff; }

        .progress-bar {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            height: 8px;
            overflow: hidden;
            margin: 0.75rem 0;
        }
        .progress-fill {
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
            width: 0%;
            height: 100%;
            border-radius: 10px;
            transition: width 0.3s;
        }

        .two-columns {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .footer {
            text-align: center;
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-light);
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .refresh-indicator {
            text-align: right;
            font-size: 0.7rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }

        @media (max-width: 768px) {
            body { padding: 1rem; }
            .metric { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
<div class="dashboard">
    <div class="refresh-indicator" id="refreshTime">Last update: --:--:--</div>
    <h1>⚜️ CrownStar‑Absolute</h1>
    <div class="subtitle">Diagnostics Dashboard – Real‑time Health Metrics</div>

    <div class="grid">
        <!-- System Info Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">🖥️</span>
                <h3>System Overview</h3>
            </div>
            <div class="metric" id="hostname">---</div>
            <div class="metric-label">Hostname</div>
            <div class="two-columns" style="margin-top: 0.75rem;">
                <div><span class="metric-label">OS</span><br><span id="os">---</span></div>
                <div><span class="metric-label">Python</span><br><span id="pythonVer">---</span></div>
                <div><span class="metric-label">PyTorch</span><br><span id="torchVer">---</span></div>
            </div>
            <div class="progress-bar" style="margin-top: 0.75rem;">
                <div class="progress-fill" id="cpuProgress" style="width:0%"></div>
            </div>
            <div><span class="metric-label">CPU Usage</span> <span id="cpuPercent">0</span>%</div>
        </div>

        <!-- Memory Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">🧠</span>
                <h3>Memory Usage</h3>
            </div>
            <div class="metric" id="ramUsed">0 <span class="metric-unit">GB</span></div>
            <div class="progress-bar"><div class="progress-fill" id="ramProgress" style="width:0%"></div></div>
            <div class="two-columns">
                <div><span class="metric-label">Total RAM</span><br><span id="ramTotal">0</span> GB</div>
                <div><span class="metric-label">Available</span><br><span id="ramAvail">0</span> GB</div>
                <div><span class="metric-label">Process RSS</span><br><span id="processRSS">0</span> MB</div>
            </div>
        </div>

        <!-- GPU Card (if available) -->
        <div class="card" id="gpuCard" style="display: none;">
            <div class="card-header">
                <span class="icon">🎮</span>
                <h3>GPU</h3>
            </div>
            <div class="metric" id="gpuName">---</div>
            <div class="metric-label" id="gpuMemLabel">Memory</div>
            <div class="progress-bar"><div class="progress-fill" id="gpuProgress" style="width:0%"></div></div>
            <div class="two-columns">
                <div><span class="metric-label">Allocated</span><br><span id="gpuAllocated">0</span> MB</div>
                <div><span class="metric-label">Reserved</span><br><span id="gpuReserved">0</span> MB</div>
                <div><span class="metric-label">Total</span><br><span id="gpuTotal">0</span> MB</div>
            </div>
            <div><span class="metric-label">Temperature</span> <span id="gpuTemp">N/A</span> °C</div>
        </div>

        <!-- Model Status Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">🤖</span>
                <h3>Model Status</h3>
            </div>
            <div><span class="metric-label">Tier</span> <strong id="modelTier">---</strong></div>
            <div><span class="metric-label">Device</span> <span id="modelDevice">---</span></div>
            <div><span class="metric-label">Parameters</span> <span id="modelParams">---</span></div>
            <div><span class="metric-label">Status</span> <span id="modelStatus" class="status-badge status-ok">Loaded</span></div>
        </div>

        <!-- Request Metrics Card -->
        <div class="card">
            <div class="card-header">
                <span class="icon">📊</span>
                <h3>Request Metrics</h3>
            </div>
            <div class="metric" id="reqRate">0 <span class="metric-unit">req/s</span></div>
            <div class="two-columns">
                <div><span class="metric-label">Total Requests</span><br><span id="totalReqs">0</span></div>
                <div><span class="metric-label">Avg Latency</span><br><span id="avgLatency">0</span> ms</div>
                <div><span class="metric-label">p95 Latency</span><br><span id="p95Latency">0</span> ms</div>
            </div>
            <div class="progress-bar"><div class="progress-fill" id="quotaProgress" style="width:0%"></div></div>
            <div><span class="metric-label">Daily Quota Used</span> <span id="quotaUsed">0</span>%</div>
        </div>

        <!-- Internet Cortex Status -->
        <div class="card">
            <div class="card-header">
                <span class="icon">🌐</span>
                <h3>Internet Cortex</h3>
            </div>
            <div><span class="metric-label">Status</span> <span id="cortexStatus" class="status-badge status-ok">Active</span></div>
            <div><span class="metric-label">Harvests (24h)</span> <span id="harvestCount">0</span></div>
            <div><span class="metric-label">Protocols Enabled</span> <span id="protocolsEnabled">0</span>/200</div>
            <div><span class="metric-label">Cache Hit Rate</span> <span id="cacheHitRate">0</span>%</div>
        </div>
    </div>

    <div class="footer">
        Auto‑refresh every 5 seconds | Data via pywebview API or /metrics endpoint
    </div>
</div>

<script>
    // Helper to fetch data from pywebview API or fallback to mock
    async function fetchMetrics() {
        let data = {};
        // Try pywebview API first
        if (typeof pywebview !== 'undefined' && pywebview.api && pywebview.api.get_stats) {
            try {
                const stats = await pywebview.api.get_stats();
                data = stats;
                data._source = 'pywebview';
            } catch(e) { console.warn('pywebview get_stats failed', e); }
        }
        // If no pywebview, try HTTP /metrics endpoint (if headless API running)
        if (!data._source && typeof fetch !== 'undefined') {
            try {
                const resp = await fetch('/metrics');
                if (resp.ok) data = await resp.json();
                data._source = 'http';
            } catch(e) { /* ignore */ }
        }
        // Fallback to mock data (simulate realistic values)
        if (!data._source) {
            data = generateMockData();
            data._source = 'mock';
        }
        return data;
    }

    function generateMockData() {
        const now = Date.now();
        const uptime = Math.floor((now - 1700000000000) / 1000);
        return {
            system: {
                hostname: 'CrownStar-Absolute',
                platform: 'Windows 11',
                python_version: '3.11.5',
                torch_version: '2.1.0',
                cpu_percent: Math.floor(Math.random() * 60) + 10,
                cpu_count: 8
            },
            memory: {
                total_gb: 31.9,
                available_gb: 20 + Math.random() * 10,
                process_rss_mb: 1200 + Math.random() * 400,
                used_gb: 12 + Math.random() * 8
            },
            gpu: {
                available: Math.random() > 0.3,
                name: 'NVIDIA RTX 4090',
                allocated_mb: 4000 + Math.random() * 4000,
                reserved_mb: 6000 + Math.random() * 3000,
                total_mb: 24576,
                temperature: 65 + Math.random() * 15
            },
            model: {
                tier: 'enterprise',
                device: 'cuda:0',
                parameters: 7_000_000_000,
                loaded: true
            },
            requests: {
                total: 12500 + Math.floor(Math.random() * 500),
                rate_per_sec: 3.2 + Math.random() * 5,
                avg_latency_ms: 320 + Math.random() * 100,
                p95_latency_ms: 520 + Math.random() * 150,
                quota_used_percent: 23 + Math.random() * 10
            },
            cortex: {
                active: true,
                harvests_24h: 342 + Math.floor(Math.random() * 100),
                protocols_enabled: 198,
                cache_hit_rate: 72 + Math.random() * 15
            }
        };
    }

    function updateUI(data) {
        // System
        if (data.system) {
            document.getElementById('hostname').innerText = data.system.hostname || 'CrownStar';
            document.getElementById('os').innerText = data.system.platform || 'Unknown';
            document.getElementById('pythonVer').innerText = data.system.python_version || '3.11';
            document.getElementById('torchVer').innerText = data.system.torch_version || '2.1.0';
            const cpuPct = data.system.cpu_percent || 0;
            document.getElementById('cpuPercent').innerText = cpuPct;
            document.getElementById('cpuProgress').style.width = Math.min(100, cpuPct) + '%';
        }
        // Memory
        if (data.memory) {
            const usedGB = data.memory.used_gb || (data.memory.total_gb - data.memory.available_gb);
            document.getElementById('ramUsed').innerHTML = usedGB.toFixed(1) + ' <span class="metric-unit">GB</span>';
            const ramPct = (usedGB / data.memory.total_gb) * 100;
            document.getElementById('ramProgress').style.width = Math.min(100, ramPct) + '%';
            document.getElementById('ramTotal').innerText = data.memory.total_gb?.toFixed(1) || '0';
            document.getElementById('ramAvail').innerText = data.memory.available_gb?.toFixed(1) || '0';
            document.getElementById('processRSS').innerText = data.memory.process_rss_mb?.toFixed(0) || '0';
        }
        // GPU
        if (data.gpu && data.gpu.available) {
            document.getElementById('gpuCard').style.display = 'block';
            document.getElementById('gpuName').innerText = data.gpu.name || 'GPU';
            const allocMB = data.gpu.allocated_mb || 0;
            const totalMB = data.gpu.total_mb || 1;
            const gpuPct = (allocMB / totalMB) * 100;
            document.getElementById('gpuProgress').style.width = Math.min(100, gpuPct) + '%';
            document.getElementById('gpuAllocated').innerText = allocMB.toFixed(0);
            document.getElementById('gpuReserved').innerText = (data.gpu.reserved_mb || 0).toFixed(0);
            document.getElementById('gpuTotal').innerText = totalMB.toFixed(0);
            document.getElementById('gpuTemp').innerText = data.gpu.temperature?.toFixed(0) || 'N/A';
        } else {
            document.getElementById('gpuCard').style.display = 'none';
        }
        // Model
        if (data.model) {
            document.getElementById('modelTier').innerText = data.model.tier || 'free';
            document.getElementById('modelDevice').innerText = data.model.device || 'cpu';
            const params = data.model.parameters;
            document.getElementById('modelParams').innerText = params ? (params / 1e6).toFixed(0) + 'M' : 'N/A';
            const status = data.model.loaded ? 'Loaded' : 'Error';
            document.getElementById('modelStatus').innerText = status;
            document.getElementById('modelStatus').className = data.model.loaded ? 'status-badge status-ok' : 'status-badge status-error';
        }
        // Requests
        if (data.requests) {
            document.getElementById('reqRate').innerHTML = data.requests.rate_per_sec?.toFixed(1) + ' <span class="metric-unit">req/s</span>';
            document.getElementById('totalReqs').innerText = data.requests.total?.toLocaleString() || '0';
            document.getElementById('avgLatency').innerText = data.requests.avg_latency_ms?.toFixed(0) || '0';
            document.getElementById('p95Latency').innerText = data.requests.p95_latency_ms?.toFixed(0) || '0';
            const quotaPct = data.requests.quota_used_percent || 0;
            document.getElementById('quotaProgress').style.width = Math.min(100, quotaPct) + '%';
            document.getElementById('quotaUsed').innerText = quotaPct.toFixed(1);
        }
        // Cortex
        if (data.cortex) {
            const active = data.cortex.active;
            document.getElementById('cortexStatus').innerText = active ? 'Active' : 'Inactive';
            document.getElementById('cortexStatus').className = active ? 'status-badge status-ok' : 'status-badge status-warning';
            document.getElementById('harvestCount').innerText = data.cortex.harvests_24h || '0';
            document.getElementById('protocolsEnabled').innerText = data.cortex.protocols_enabled || '0';
            document.getElementById('cacheHitRate').innerText = data.cortex.cache_hit_rate?.toFixed(0) || '0';
        }
        // Refresh time
        const now = new Date();
        document.getElementById('refreshTime').innerHTML = `Last update: ${now.toLocaleTimeString()}`;
    }

    async function refresh() {
        try {
            const data = await fetchMetrics();
            updateUI(data);
        } catch(e) {
            console.error('Refresh error', e);
            document.getElementById('refreshTime').innerHTML = 'Last update: error – retrying';
        }
    }

    // Auto-refresh every 5 seconds
    refresh();
    setInterval(refresh, 5000);
</script>
</body>
</html>

